{
    "name": "halilcosdu/laravel-chatbot",
    "description": "A Laravel-native OpenAI chatbot powered by the Responses and Conversations APIs.",
    "keywords": [
        "ai",
        "chatbot",
        "laravel",
        "laravel-chatbot",
        "openai",
        "responses-api"
    ],
    "homepage": "https://github.com/halilcosdu/laravel-chatbot",
    "license": "MIT",
    "authors": [
        {
            "name": "Halil Cosdu",
            "email": "halilcosdu@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.29 || ^12.12 || ^13.0",
        "openai-php/laravel": "^0.20",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^2.9 || ^3.0",
        "laravel/pint": "^1.25",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^2.34 || ^3.8 || ^4.0",
        "pestphp/pest-plugin-arch": "^2.7 || ^3.1 || ^4.0",
        "pestphp/pest-plugin-laravel": "^2.3 || ^3.2 || ^4.0",
        "phpstan/extension-installer": "^1.4 || ^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "HalilCosdu\\ChatBot\\": "src/",
            "HalilCosdu\\ChatBot\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HalilCosdu\\ChatBot\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-chatbot --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "format": "vendor/bin/pint",
        "format-test": "vendor/bin/pint --test",
        "test": "vendor/bin/pest --ci --no-coverage",
        "test-all": [
            "@composer validate --strict --no-check-publish",
            "@composer audit",
            "@composer format-test",
            "@composer analyse",
            "@composer test"
        ],
        "test-coverage": "vendor/bin/pest --ci --coverage"
    },
    "config": {
        "sort-packages": true,
        "audit": {
            "abandoned": "fail"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HalilCosdu\\ChatBot\\ChatBotServiceProvider"
            ],
            "aliases": {
                "ChatBot": "HalilCosdu\\ChatBot\\Facades\\ChatBot"
            }
        }
    },
    "support": {
        "issues": "https://github.com/halilcosdu/laravel-chatbot/issues",
        "source": "https://github.com/halilcosdu/laravel-chatbot"
    },
    "prefer-stable": true
}
